# =============================================================================
# 프론트엔드 (Vite) — VITE_ 접두어 값만 클라이언트 번들에 포함됩니다.
# 이 값들은 브라우저에 노출되는 것이 정상입니다(Firebase 공개 설정 키).
# 실제 접근 통제는 Firestore 보안 규칙(firestore.rules)으로 수행합니다.
#
# 참고: Firebase 공개 설정은 src/firebaseConfig.ts 에 이미 커밋되어 있으므로
# 아래 VITE_FIREBASE_* 값은 "다른 프로젝트로 바꾸고 싶을 때만" 채우면 됩니다(선택).
# =============================================================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 로그인을 허용할 단일 사용자 계정 (Firestore 규칙의 OWNER_UID와 일치해야 함)
VITE_ALLOWED_EMAIL=soojhann@seoulav.co.kr

# GitHub Pages base 경로 오버라이드(선택). 프로젝트 페이지면 비워둬도 됩니다.
# VITE_BASE=/my-personal-assistant-/

# =============================================================================
# 자동화 스크립트 / GitHub Actions 전용 (절대 커밋 금지 — GitHub Secrets에 저장)
# 로컬 테스트 시에만 .env 로 복사해서 사용하세요.
# =============================================================================

# Firebase Admin SDK 서비스 계정(JSON 전체를 한 줄 문자열로)
FIREBASE_SERVICE_ACCOUNT=

# Anthropic Claude API
ANTHROPIC_API_KEY=
# 뉴스 요약/카드뉴스 생성에 사용할 모델
CLAUDE_MODEL=claude-sonnet-5

# Google Calendar (OAuth2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# 네이버 뉴스 검색 API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Gmail SMTP (앱 비밀번호) — 이메일 발송용. 주로 GitHub Actions에서 직접 사용.
MAIL_USERNAME=
MAIL_APP_PASSWORD=
MAIL_TO=soojhann@seoulav.co.kr

# 대시보드 링크(이메일 본문에 삽입)
DASHBOARD_URL=https://supaper.github.io/my-personal-assistant-/
