{
  "name": "my-personal-assistant",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "개인 업무 자동화 어시스턴트 — 매일 아침 일정·경제·교육 뉴스 브리핑",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
