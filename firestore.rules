rules_version = '2';

// 개인 전용(1인) 어시스턴트: 오직 소유자 UID만 read/write 가능.
// 배포 전 반드시 아래 OWNER_UID 를 본인 Firebase Auth UID로 교체할 것.
// (Google 로그인 후 대시보드 개발자 콘솔 또는 Firebase 콘솔에서 UID 확인)
//
// 자동화 스크립트(GitHub Actions)는 firebase-admin(서비스 계정)으로 접근하며
// Admin SDK는 보안 규칙을 우회하므로 여기서 별도로 허용할 필요가 없다.
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner() {
      return request.auth != null
        && request.auth.uid == 'REPLACE_WITH_OWNER_UID';
    }

    match /{document=**} {
      allow read, write: if isOwner();
    }
  }
}
