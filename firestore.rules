rules_version = '2';

// 개인 전용(1인) 어시스턴트: 오직 소유자 이메일로 로그인한 경우에만 read/write 허용.
// 이메일 기반이라 UID를 따로 조회해 붙여넣을 필요가 없다.
// 소유자 이메일을 바꾸려면 아래 OWNER_EMAIL 값과 src/firebaseConfig.ts의
// defaultAllowedEmail(및 VITE_ALLOWED_EMAIL)을 함께 갱신한다.
//
// 자동화 스크립트(GitHub Actions)는 firebase-admin(서비스 계정)으로 접근하며
// Admin SDK는 보안 규칙을 우회하므로 여기서 별도로 허용할 필요가 없다.
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'soojhann@seoulav.co.kr';
    }

    match /{document=**} {
      allow read, write: if isOwner();
    }
  }
}
